# ==============================================================================
# .gitignore — Lumina LM
#
# Standard ignore file for Bash shell script projects.
# ==============================================================================

# ------------------------------------------------------------------------------
# Sistema operacional
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# IDEs e editores
# ------------------------------------------------------------------------------
.idea/
.vscode/
.vscodium/
.zed/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Build, cache e temporários
# ------------------------------------------------------------------------------
/dist/
/build/
/.cache/
/.tmp/
/tmp/
*.log
*.log.*

# ------------------------------------------------------------------------------
# Ferramentas de IA (configs locais, histórico e instruções de agentes)
# ------------------------------------------------------------------------------

# Arquivos de exclusão de contexto para IA
.aiexclude
.geminiignore
.aignore
.aiignore

# Claude Code (Anthropic)
.claude/

# OpenAI Codex
.codex
.codex/

# Google Gemini
.gemini/

# Cursor AI
.cursor/
.cursorrules
.cursorignore

# Windsurf (Codeium)
.windsurfrules
.windsurf/

# Aider
.aider*
aider.conf.yml

# Continue.dev
.continue/

# Codeium
.codeium/

# Tabnine
.tabnine/


# ------------------------------------------------------------------------------
# Credenciais e segurança
# ------------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets.*
*.secret
.htpasswd
auth.json
.env
.env.*
*.env
