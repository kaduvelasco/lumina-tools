# ==============================================================================
# .gitignore — Lumina
# This is a generic file; adjust it to your needs.
# ==============================================================================

# Operating System
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDEs and Editors
.idea/
.vscode/
.vscodium/
.zed/
.project
.classpath
.settings/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Dependencies and Package Managers
node_modules/
vendor/
bower_components/
.npm/
.yarn/

# Lockfiles (keep composer.lock for PHP projects; remove only if your team manages versions manually)
package-lock.json
yarn.lock

# Go
*.test
coverage.out
coverage.html
*.prof
*.trace
cpu.out
mem.out

# Build, Cache, and Temporaries
dist/
build/
.cache/
.tmp/
tmp/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Moodle Specific
moodledata/
config.php
*.session

# PHP & Security
.env
.env.*
*.env
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets.*
*.secret
.htpasswd
auth.json
wp-config.php

# AI Tools & MCPs (Code Assistants)

# Context Exclusion Files
.aignore
.aiignore
.cursorignore
.code-review-graphignore

# Rule and Instruction Files (Local)
aider.conf.yml

# Agent Data Directories
.claude/
.gemini/
.cursor/
.windsurf/
.aider*
.continue/
.codeium/
.tabnine/
.codex/
.codex

# MCPs, Graphs, and Other Metadata
.mcp.json
.opencode.json
.aivault.json
.kiro/
.code-review-graph/
